# Modo demo: sirve datos ficticios, desactiva Supabase y omite el login.
# Es el modo con el que se despliega esta demo publica.
PORTFOLIO_DEMO_MODE=true

# Solo necesario si PORTFOLIO_DEMO_MODE esta apagado.
# Generar uno aleatorio y largo, por ejemplo con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=genera_un_secreto_aleatorio_largo
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key
SUPABASE_KEY=tu_anon_o_publishable_key
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key
GEMINI_API_KEY=tu_gemini_api_key
